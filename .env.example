# ─── App ──────────────────────────────────────────────────────────────────────
# Base URL for the application (used in meta tags and canonical links)
VITE_APP_URL=http://localhost:5173

# Display name shown in the browser tab and page titles
VITE_APP_NAME=Buildpio OS

# ─── API (future: replace mock data with a real backend) ──────────────────────
# Base URL for the REST / GraphQL API
# VITE_API_URL=https://api.your-domain.com

# ─── Authentication (future: JWT or OAuth) ────────────────────────────────────
# Your OAuth client ID (e.g. GitHub, Google)
# VITE_AUTH_CLIENT_ID=

# OAuth redirect URI after successful login
# VITE_AUTH_REDIRECT_URI=http://localhost:5173/auth/callback

# ─── Analytics (optional) ─────────────────────────────────────────────────────
# Tracking ID for a product analytics provider (e.g. Posthog, Mixpanel)
# VITE_ANALYTICS_ID=

# ─── Feature flags (optional) ─────────────────────────────────────────────────
# Enable the live data layer (set to "true" once the API is connected)
# VITE_ENABLE_LIVE_DATA=false

# Enable real-time WebSocket updates for the activity feed
# VITE_ENABLE_REALTIME=false
